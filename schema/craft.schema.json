{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/sos/schema/Craft.schema.json",
  "title": "Craft",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "Craft"
    },
    "name": {
      "type": "string"
    },
    "domain_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "position": {
      "type": "string",
      "enum": [
        "meta_craft",
        "craft",
        "subcraft"
      ]
    },
    "principles": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "maxims": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "heuristics": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "models": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "memo",
        "draft",
        "forged",
        "honed",
        "ratified",
        "archived"
      ]
    }
  },
  "required": [
    "id",
    "type",
    "name",
    "domain_ids",
    "source_ids",
    "position",
    "status"
  ]
}
