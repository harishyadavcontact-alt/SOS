{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/sos/schema/Protocol.schema.json",
  "title": "Protocol",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "Protocol"
    },
    "name": {
      "type": "string"
    },
    "craft_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "code_of_conduct_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "trigger_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "kill_rule": {
      "type": "string"
    },
    "review_cadence": {
      "type": "string",
      "enum": [
        "daily",
        "weekly",
        "monthly",
        "quarterly",
        "event_driven"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "retired"
      ]
    }
  },
  "required": [
    "id",
    "type",
    "name",
    "trigger_conditions",
    "steps",
    "kill_rule",
    "review_cadence",
    "status"
  ]
}
