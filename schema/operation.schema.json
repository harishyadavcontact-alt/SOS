{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/sos/schema/Operation.schema.json",
  "title": "Operation",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "Operation"
    },
    "name": {
      "type": "string"
    },
    "operation_type": {
      "type": "string",
      "enum": [
        "horizontal",
        "vertical"
      ]
    },
    "mission_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "owner_id": {
      "type": "string"
    },
    "protocol_ids": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "start_date": {
      "anyOf": [
        {
          "type": "string",
          "format": "date"
        },
        {
          "type": "null"
        }
      ]
    },
    "end_date": {
      "anyOf": [
        {
          "type": "string",
          "format": "date"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "active",
        "complete",
        "aborted",
        "archived"
      ]
    }
  },
  "required": [
    "id",
    "type",
    "name",
    "operation_type",
    "owner_id",
    "status"
  ]
}
