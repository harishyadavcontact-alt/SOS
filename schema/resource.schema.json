{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/sos/schema/Resource.schema.json",
  "title": "Resource",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "Resource"
    },
    "name": {
      "type": "string"
    },
    "resource_type": {
      "type": "string",
      "enum": [
        "asset",
        "liability"
      ]
    },
    "owner_id": {
      "type": "string"
    },
    "domain_ids": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "quantity": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "unit": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "liquidity": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "criticality_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "depleted",
        "growing",
        "impaired"
      ]
    }
  },
  "required": [
    "id",
    "type",
    "name",
    "resource_type",
    "owner_id",
    "criticality_score",
    "status"
  ]
}
