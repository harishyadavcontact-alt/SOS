{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/sos/schema/Agent.schema.json",
  "title": "Agent",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "const": "Agent"
    },
    "name": {
      "type": "string"
    },
    "lineage_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "authority_level": {
      "type": "string"
    },
    "skin_in_game_score": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ]
    }
  },
  "required": [
    "id",
    "type",
    "name",
    "authority_level",
    "skin_in_game_score",
    "status"
  ]
}
